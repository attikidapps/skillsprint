# Supabase (get from Project Settings → API at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (used for SEO metadata, sitemap, auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic API key (for AI lesson generator — get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# PostHog analytics (optional — create a project at posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
